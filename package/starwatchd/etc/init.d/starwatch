#!/bin/sh /etc/rc.common
# procd service for starwatchd
USE_PROCD=1
START=95
STOP=10

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/starwatchd -config /etc/config/starwatch
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	# The daemon applies safe settings through its API; a procd config reload
	# restarts it so restart-managed UCI settings also take effect.
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "starwatch"
}
