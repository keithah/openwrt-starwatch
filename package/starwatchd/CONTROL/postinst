#!/bin/sh
[ -n "$IPKG_INSTROOT" ] && exit 0

/usr/libexec/keithah-feed-migrate
/etc/uci-defaults/99-starwatch
/etc/init.d/starwatch enable
# restart (not start) so an upgrade picks up the new binary and the
# freshly-generated token; restart also starts a stopped service.
/etc/init.d/starwatch restart
exit 0
